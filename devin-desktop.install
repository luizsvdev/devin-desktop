post_install() {
    update-desktop-database -q
    update-mime-database /usr/share/mime

    xdg-mime default devin-desktop.desktop x-scheme-handler/devin
    xdg-mime default devin-desktop.desktop x-scheme-handler/codeium

    echo "Devin Desktop protocol handlers registered"
}

post_upgrade() {
    post_install
}
